# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Configuration
# Generate a secure random string for production (e.g., using: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-here

# MongoDB Configuration
# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/content_quality_reviewer?retryWrites=true&w=majority

# Application Configuration
# Maximum content length in words for analysis
MAX_CONTENT_LENGTH=2000

# Rate Limiting Configuration
# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW=60
# Maximum number of requests allowed per window
RATE_LIMIT_MAX=10

# OpenAI Model Configuration
# Model to use for content analysis (gpt-4-turbo-preview, gpt-3.5-turbo, etc.)
OPENAI_MODEL=gpt-4-turbo-preview
# Maximum tokens for OpenAI responses
OPENAI_MAX_TOKENS=2000
# Temperature for OpenAI responses (0.0 - 1.0)
OPENAI_TEMPERATURE=0.3

# Storage Configuration
# TTL for analysis results in days
ANALYSIS_TTL_DAYS=30
